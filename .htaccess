# Boutique Hotel Zanzibar lander — Apache config (All-Inkl webspace /33/)
# Generated by Matlai automation 2026-05-27

# ---- Force HTTPS (301 from HTTP to HTTPS) ----
RewriteEngine On
RewriteCond %{HTTPS} !=on
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# ---- Extra noindex insurance via X-Robots-Tag header ----
# Belt-and-braces in addition to <meta name="robots"> in every HTML file.
<IfModule mod_headers.c>
  Header set X-Robots-Tag "noindex, follow, noarchive, noai, noimageai"
  # Block iframes from other origins (clickjacking protection)
  Header set X-Frame-Options "SAMEORIGIN"
  # Don't leak referrer info to less-secure pages
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  # Force HTTPS in supporting browsers (1-year HSTS)
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ---- Cache static assets aggressively (1 year) ----
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png  "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType video/mp4  "access plus 1 year"
  ExpiresByType video/webm "access plus 1 year"
  ExpiresByType text/css   "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/html "access plus 5 minutes"
</IfModule>

# ---- Force HTML handling for index.<lang>.html files ----
# Apache may treat .pl.html as a Perl CGI script and 403 it; this overrides.
<FilesMatch "^index\.(en|de|es|fr|it|pl)\.html$">
    SetHandler default-handler
    ForceType text/html
    Options -ExecCGI
    RemoveHandler .pl .cgi
</FilesMatch>

# ---- Hide .git in case it ever lands here again ----
RedirectMatch 404 /\.git
RedirectMatch 404 /\.env
RedirectMatch 404 /\.DS_Store

# ---- 404 fallback ----
ErrorDocument 404 /index.html
